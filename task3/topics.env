# Shared Task 3 topic names and Kafka CLI settings.
KAFKA_BOOTSTRAP_SERVER=localhost:9092
KAFKA_DOCKER_SERVICE=kafka
KAFKA_TOPICS_BIN=/opt/kafka/bin/kafka-topics.sh
KAFKA_CONSOLE_PRODUCER_BIN=/opt/kafka/bin/kafka-console-producer.sh
KAFKA_CONSOLE_CONSUMER_BIN=/opt/kafka/bin/kafka-console-consumer.sh

KAFKA_PARTITIONS=1
KAFKA_REPLICATION_FACTOR=1

TOPIC_NODES=cpg.nodes
TOPIC_EDGES=cpg.edges
TOPIC_METADATA=cpg.metadata
TOPIC_ERRORS=cpg.errors
