{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/linh285/huggingface-cpg-streaming/task3/schemas/error-event.schema.json",
  "title": "Parser error event",
  "type": "object",
  "required": [
    "schema_version",
    "event_type",
    "event_time",
    "repository",
    "file_id",
    "path",
    "content_sha256",
    "error_id",
    "error_type",
    "error_message",
    "lineno",
    "col_offset"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "event_type": { "const": "PARSER_ERROR" },
    "event_time": { "type": "string", "format": "date-time" },
    "repository": { "type": "string", "minLength": 1 },
    "file_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "path": { "type": "string", "minLength": 1 },
    "content_sha256": { "type": "string", "pattern": "^([0-9a-f]{64})?$" },
    "error_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "error_type": { "type": "string", "minLength": 1 },
    "error_message": { "type": "string", "minLength": 1 },
    "lineno": { "type": "integer", "minimum": 0 },
    "col_offset": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
