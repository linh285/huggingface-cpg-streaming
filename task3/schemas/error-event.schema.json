{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/linh285/huggingface-cpg-streaming/task3/schemas/error-event.schema.json",
  "title": "Parser Error Event",
  "description": "Event emitted to cpg.errors when the CPG parser fails to process a file.",
  "type": "object",
  "required": [
    "schema_version",
    "event_type",
    "event_time",
    "repository",
    "commit_sha",
    "file_id",
    "file_path",
    "content_hash",
    "error_id",
    "stage",
    "error_type",
    "message",
    "retryable"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "event_type":     { "const": "PARSER_ERROR" },
    "event_time":     { "type": "string", "format": "date-time" },
    "repository":     { "type": "string", "minLength": 1 },
    "commit_sha":     { "type": "string", "minLength": 7 },
    "file_id":        { "type": "string", "minLength": 1 },
    "file_path":      { "type": "string", "minLength": 1 },
    "content_hash":   { "type": "string", "minLength": 1 },
    "error_id":       { "type": "string", "minLength": 1 },
    "stage":          { "type": "string", "minLength": 1 },
    "error_type":     { "type": "string", "minLength": 1 },
    "message":        { "type": "string", "minLength": 1 },
    "line":           { "type": ["integer", "null"], "minimum": 1 },
    "column":         { "type": ["integer", "null"], "minimum": 0 },
    "retryable":      { "type": "boolean" }
  },
  "additionalProperties": true
}
