{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/linh285/huggingface-cpg-streaming/task3/schemas/node-event.schema.json",
  "title": "CPG node change event",
  "type": "object",
  "required": [
    "schema_version",
    "event_type",
    "event_time",
    "repository",
    "file_id",
    "path",
    "content_sha256",
    "node_id"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "event_type": { "enum": ["NODE_UPSERT", "NODE_DELETE"] },
    "event_time": { "type": "string", "format": "date-time" },
    "repository": { "type": "string", "minLength": 1 },
    "file_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "path": { "type": "string", "minLength": 1 },
    "content_sha256": { "type": "string", "pattern": "^([0-9a-f]{64})?$" },
    "node_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "structural_path": { "type": "string", "minLength": 1 },
    "node_type": { "type": "string", "minLength": 1 },
    "label": { "type": "string" },
    "lineno": { "type": "integer", "minimum": 0 },
    "col_offset": { "type": "integer", "minimum": 0 },
    "end_lineno": { "type": "integer", "minimum": 0 },
    "end_col_offset": { "type": "integer", "minimum": 0 },
    "code": { "type": "string" },
    "properties": { "type": "object" }
  },
  "allOf": [
    {
      "if": { "properties": { "event_type": { "const": "NODE_UPSERT" } } },
      "then": {
        "required": [
          "structural_path",
          "node_type",
          "label",
          "lineno",
          "col_offset",
          "end_lineno",
          "end_col_offset",
          "code",
          "properties"
        ]
      }
    }
  ],
  "additionalProperties": false
}
