{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/linh285/huggingface-cpg-streaming/task3/schemas/edge-event.schema.json",
  "title": "CPG edge change event",
  "type": "object",
  "required": [
    "schema_version",
    "event_type",
    "event_time",
    "repository",
    "file_id",
    "path",
    "content_sha256",
    "edge_id",
    "edge_type",
    "source_id",
    "target_id"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "event_type": { "enum": ["EDGE_UPSERT", "EDGE_DELETE"] },
    "event_time": { "type": "string", "format": "date-time" },
    "repository": { "type": "string", "minLength": 1 },
    "file_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "path": { "type": "string", "minLength": 1 },
    "content_sha256": { "type": "string", "pattern": "^([0-9a-f]{64})?$" },
    "edge_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "edge_type": { "enum": ["AST", "CFG", "DFG", "CALL"] },
    "source_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "target_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "properties": { "type": "object" }
  },
  "allOf": [
    {
      "if": { "properties": { "event_type": { "const": "EDGE_UPSERT" } } },
      "then": { "required": ["properties"] }
    }
  ],
  "additionalProperties": false
}
